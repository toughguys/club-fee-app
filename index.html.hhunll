<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#2563eb">
<link rel="manifest" href="manifest.webmanifest">
<link rel="apple-touch-icon" href="icon-192.png">
<title>クラブ集金アプリ</title>
<style>
:root{--bg:#f5f7fb;--card:#fff;--line:#e5e7eb;--text:#1f2937;--sub:#6b7280;--blue:#2563eb;--blue2:#eff6ff;--green:#16a34a;--green2:#ecfdf5;--red:#dc2626}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{margin:0;background:var(--bg);color:var(--text);font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Noto Sans JP",sans-serif}
main{max-width:820px;margin:auto;padding:14px 14px calc(28px + env(safe-area-inset-bottom))}
h1{font-size:1.45rem;margin:8px 0 4px}.sub,.small{color:var(--sub);font-size:.88rem;line-height:1.5}
.card{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:14px;margin:12px 0;box-shadow:0 6px 18px rgba(0,0,0,.05)}
.row{display:flex;gap:10px;align-items:end;flex-wrap:wrap}.grow{flex:1;min-width:180px}
label{display:block;color:var(--sub);font-size:.82rem;margin-bottom:5px}
input[type=date],input[type=text],select,textarea{width:100%;border:1px solid var(--line);border-radius:12px;padding:12px;font-size:1rem;background:#fff}
textarea{min-height:150px;line-height:1.6}
button{border:0;border-radius:12px;padding:12px 15px;font-size:1rem;font-weight:700;cursor:pointer;min-height:46px}
.primary{background:var(--blue);color:#fff}.secondary{background:var(--blue2);color:#1d4ed8}.ghost{background:#f3f4f6;color:#374151}.danger{background:#fee2e2;color:var(--red)}
.fee{display:grid;grid-template-columns:1fr 1fr;gap:10px}.fee button{font-size:1.1rem}
.group{margin-top:14px;border:1px solid var(--line);border-radius:15px;overflow:hidden}
.group-head{width:100%;display:flex;justify-content:space-between;align-items:center;background:#f8fafc;color:var(--text);border-radius:0;padding:13px 14px;text-align:left}
.group.closed .group-body{display:none}.group.closed .chev{transform:rotate(-90deg)}.chev{display:inline-block;transition:.2s}
.member{display:grid;grid-template-columns:32px 1fr 38px;gap:10px;align-items:center;padding:13px 12px;border-top:1px solid #eef0f3;min-height:58px;cursor:pointer}
.member.checked{background:var(--green2)}.member input{width:24px;height:24px;accent-color:var(--green);pointer-events:none}.member-name{font-size:1.08rem;font-weight:750}
.member .delete{padding:6px 10px;min-height:38px}
.summary{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-top:14px}.summary div{background:#f8fafc;border-radius:14px;padding:12px;text-align:center}.summary strong{display:block;font-size:1.25rem;margin-top:4px}
.actions{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:14px}.wide{grid-column:1/-1}
.hidden{display:none}.history-item{padding:11px 0;border-bottom:1px solid #eef0f3}.history-head{display:flex;justify-content:space-between;font-weight:800}
.notice{background:#fff7ed;border:1px solid #fed7aa;color:#9a3412;border-radius:12px;padding:11px;font-size:.88rem;line-height:1.5}
@media(max-width:560px){main{padding-left:10px;padding-right:10px}.summary,.actions{grid-template-columns:1fr}.wide{grid-column:auto}}
</style>
</head>
<body>
<main>
<h1>体育館利用料</h1>
<p id="clubLabel" class="sub" style="font-weight:700;color:#374151">○○クラブ</p>
<p class="sub">iPhone・Android対応。名簿と履歴は、それぞれの端末内だけに保存されます。</p>

<section class="card">
<div class="row">
<div class="grow"><label>利用日</label><input id="date" type="date"></div>
<div style="min-width:210px;flex:1"><label>今日の集金額</label>
<div class="fee"><button id="f100" class="primary">100円</button><button id="f200" class="ghost">200円</button></div>
<input id="fee" type="hidden" value="100"></div>
</div>
</section>

<section class="card">
<div class="row" style="justify-content:space-between;align-items:center"><strong>集金名簿</strong><button id="openSettings" class="secondary">⚙️ 設定</button></div>
<div id="groups"></div>
<div class="summary"><div>集金人数<strong id="count">0人</strong></div><div>未集金<strong id="unpaid">0人</strong></div><div>合計<strong id="total">0円</strong></div></div>
<div class="actions"><button id="start" class="secondary wide">今日を開始</button><button id="save" class="primary">今日を保存</button><button id="reset" class="ghost">チェックを外す</button></div>
</section>

<section id="settings" class="card hidden">
<strong>設定</strong>

<div class="row" style="margin-top:12px">
  <button id="showMemberEdit" class="secondary">メンバー編集</button>
  <button id="showClubEdit" class="secondary">クラブ名変更</button>
</div>

<div id="memberEditArea" class="hidden" style="margin-top:14px">
  <p class="small">1人ずつ追加するか、区分ごとにまとめて貼り付けられます。</p>
  <div class="row">
    <div class="grow"><label>名前</label><input id="newName" type="text" placeholder="例：山田 花子"></div>
    <div style="min-width:150px"><label>区分</label><select id="newGroup"><option value="g3">3年生</option><option value="g2">2年生</option><option value="g1">1年生</option><option value="tr">練習生</option></select></div>
    <button id="add" class="primary">追加</button>
  </div>
  <div style="margin-top:14px">
    <label>選択中の区分へ一括追加（1行に1人）</label>
    <textarea id="bulk" placeholder="3年生 A&#10;3年生 B"></textarea>
    <button id="bulkAdd" class="secondary" style="margin-top:8px">まとめて追加</button>
  </div>
</div>

<div id="clubEditArea" class="hidden" style="margin-top:14px">
  <div class="row">
    <div class="grow"><label>クラブ名</label><input id="club" type="text"></div>
    <button id="saveClub" class="secondary">保存</button>
  </div>
</div>

<div class="notice" style="margin-top:12px">ここで入力した実名やクラブ名は、この端末内だけに保存されます。他の端末には共有されません。</div>

<div class="row" style="margin-top:14px">
  <button id="closeSettings" class="ghost">閉じる</button>
  <button id="clear" class="danger">履歴を削除</button>
</div>
</section>

<section class="card">
<div class="row" style="justify-content:space-between;align-items:center"><strong>保存した履歴</strong></div>
<div id="history"></div>
</section>
</main>
<script>
const GS=[{id:"g3",label:"登録メンバー・3年生"},{id:"g2",label:"登録メンバー・2年生"},{id:"g1",label:"登録メンバー・1年生"},{id:"tr",label:"登録なし・練習生"}];
const DEF=[{name:"3年生 A",group:"g3"},{name:"3年生 B",group:"g3"},{name:"3年生 C",group:"g3"},{name:"2年生 A",group:"g2"},{name:"2年生 B",group:"g2"},{name:"2年生 C",group:"g2"},{name:"1年生 A",group:"g1"},{name:"1年生 B",group:"g1"},{name:"1年生 C",group:"g1"},{name:"練習生 A",group:"tr"},{name:"練習生 B",group:"tr"}];
const KM="fee_members_v1",KH="fee_history_v1",KC="fee_club_v1",KG="fee_groups_v1";
let members=JSON.parse(localStorage.getItem(KM)||"null")||DEF, history=JSON.parse(localStorage.getItem(KH)||"[]"), club=localStorage.getItem(KC)||"○○クラブ", closed=JSON.parse(localStorage.getItem(KG)||"{}"), checked={};
const $=id=>document.getElementById(id), esc=s=>String(s).replace(/[&<>"']/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[c]));
$("date").value=new Date().toISOString().slice(0,10);$("clubLabel").textContent=club;$("club").value=club;
function saveMembers(){localStorage.setItem(KM,JSON.stringify(members))}
function render(){
 const box=$("groups");box.innerHTML="";
 GS.forEach(g=>{
  const list=members.map((m,i)=>({...m,i})).filter(m=>m.group===g.id), sec=document.createElement("div");sec.className="group"+(closed[g.id]?" closed":"");
  const head=document.createElement("button");head.className="group-head";head.innerHTML=`<span>${g.label}</span><span>${list.length}人 <span class="chev">▼</span></span>`;head.onclick=()=>{closed[g.id]=!closed[g.id];localStorage.setItem(KG,JSON.stringify(closed));render()};
  const body=document.createElement("div");body.className="group-body";
  if(!list.length) body.innerHTML='<div class="small" style="padding:14px">まだ登録がありません。</div>';
  list.forEach(m=>{const row=document.createElement("div");row.className="member"+(checked[m.i]?" checked":"");row.innerHTML=`<input type="checkbox" ${checked[m.i]?"checked":""}><div class="member-name">${esc(m.name)}</div><button class="danger delete">×</button>`;
   row.onclick=e=>{if(e.target.closest(".delete"))return;checked[m.i]=!checked[m.i];render()};
   row.querySelector(".delete").onclick=()=>{if(confirm(m.name+"さんを削除しますか？")){members.splice(m.i,1);checked={};saveMembers();render()}};
   body.appendChild(row)});
  sec.append(head,body);box.appendChild(sec)
 });update()
}
function update(){const fee=Number($("fee").value),n=Object.values(checked).filter(Boolean).length;$("count").textContent=n+"人";$("unpaid").textContent=Math.max(members.length-n,0)+"人";$("total").textContent=(n*fee).toLocaleString()+"円"}
function setFee(n){$("fee").value=n;$("f100").className=n===100?"primary":"ghost";$("f200").className=n===200?"primary":"ghost";update()}
$("f100").onclick=()=>setFee(100);$("f200").onclick=()=>setFee(200);
$("start").onclick=()=>{if(Object.values(checked).some(Boolean)&&!confirm("現在のチェックを消して今日を開始しますか？"))return;$("date").value=new Date().toISOString().slice(0,10);checked={};setFee(100);render()};
$("reset").onclick=()=>{if(confirm("すべてのチェックを外しますか？")){checked={};render()}};
$("openSettings").onclick=()=>{
  $("settings").classList.remove("hidden");
  setTimeout(()=>$("settings").scrollIntoView({behavior:"smooth",block:"start"}),50);
};
$("closeSettings").onclick=()=>{
  $("settings").classList.add("hidden");
  $("memberEditArea").classList.add("hidden");
  $("clubEditArea").classList.add("hidden");
  setTimeout(()=>$("openSettings").scrollIntoView({behavior:"smooth",block:"center"}),50);
};
$("showMemberEdit").onclick=()=>{
  $("memberEditArea").classList.toggle("hidden");
  $("clubEditArea").classList.add("hidden");
};
$("showClubEdit").onclick=()=>{
  $("clubEditArea").classList.toggle("hidden");
  $("memberEditArea").classList.add("hidden");
};
$("add").onclick=()=>{const name=$("newName").value.trim();if(!name)return alert("名前を入力してください。");members.push({name,group:$("newGroup").value});$("newName").value="";saveMembers();render()};
$("bulkAdd").onclick=()=>{const names=$("bulk").value.split(/\r?\n/).map(x=>x.trim()).filter(Boolean);if(!names.length)return alert("名前を入力してください。");names.forEach(name=>members.push({name,group:$("newGroup").value}));$("bulk").value="";saveMembers();render();alert(names.length+"人追加しました。")};
$("saveClub").onclick=()=>{club=$("club").value.trim()||"○○クラブ";localStorage.setItem(KC,club);$("clubLabel").textContent=club;alert("保存しました。")};
$("save").onclick=()=>{const fee=Number($("fee").value),paid=members.filter((_,i)=>checked[i]).map(m=>({...m})),rec={date:$("date").value,fee,paid,total:paid.length*fee},i=history.findIndex(h=>h.date===rec.date);if(i>=0){if(!confirm("同じ日付を上書きしますか？"))return;history[i]=rec}else history.push(rec);localStorage.setItem(KH,JSON.stringify(history));renderHistory();alert("保存しました。")};
function renderHistory(){const box=$("history");box.innerHTML="";if(!history.length){box.innerHTML='<p class="sub">まだ履歴はありません。</p>';return}[...history].reverse().forEach(h=>{const d=document.createElement("div");d.className="history-item";d.innerHTML=`<div class="history-head"><span>${esc(h.date)}</span><span>${Number(h.total).toLocaleString()}円</span></div><div class="small">1人 ${h.fee}円 ／ ${h.paid.length}人</div><div class="small">${h.paid.map(x=>esc(x.name)).join("、")||"集金なし"}</div>`;box.appendChild(d)})}
$("clear").onclick=()=>{if(history.length&&confirm("履歴をすべて削除しますか？")){history=[];localStorage.setItem(KH,"[]");renderHistory()}};
render();renderHistory();
if("serviceWorker" in navigator){window.addEventListener("load",()=>navigator.serviceWorker.register("sw.js").catch(()=>{}))}
</script>
</body>
</html>
